# 要执行的函数示例
def frequency_domain(original_data, fs, ansy_method=None, pro_method=None):
    """
    示例函数：处理用户数据
    """
    # signal = np.array(original_data)  # 1. 处理成 np.array
    # signal = (signal - np.mean(signal)).tolist()  #  2. 减去均值
    # 这里收到的原始数据就是array  不需要做np.array的处理
    print(f"original_data: {original_data}")
    original_data = np.array(original_data, dtype=float)
    signal = (original_data - np.mean(original_data)).tolist()  # 2. 减去均值
    Sampling_points = len(original_data)  # 采样点数，fft后的点数就是这个数
    df = 1 / fs  # 采样间隔时间 那样才能计算频率
    y = signal[:] # 相当于复制一份数据
    y = list(map(float, y))  # 这里又转成float
    y = np.array(y)  # 
    f_values = np.linspace(0.0, fs / 2.0, Sampling_points // 2)  # 等分数据
    fft_values_ = fft.fft(y)  # FFT变换
    fft_values = 2.0 / Sampling_points * np.abs(fft_values_[0:Sampling_points // 2])
    #print("f_values", f_values)
    i#print("fft_values", fft_values)
    # return f_values, fft_values
    result = f"原始数据长度 {len(signal)}，频率 {fs} ，算法分析方法 {ansy_method}， 预处理类型 {pro_method}"
    # 这里可以添加你的业务逻辑
    result_dict = {
        "status": "success",
        "message": result,
        "data": {
            "signal": signal,
            "fs": fs,
            "ansy_method": ansy_method,
            "pro_method": pro_method,
            "f_values": f_values.tolist() if hasattr(f_values, 'tolist') else f_values,
            "fft_values": fft_values.tolist() if hasattr(fft_values, 'tolist') else fft_values
        }
    }
    return result_dict

# 上传服务器 现在在用 需要修改的
@app.route('/api/process', methods=['GET', 'POST'])
def handle_request():
    try:
        # 根据请求方法获取参数
        if request.method == 'GET':
            # 从查询字符串获取参数
            pass
            return None
        else:  # POST 请求
            # 从表单数据或 JSON 获取数据
            if request.is_json:
                data = request.get_json()
                local_filename = data.get('localfilename')
                analyse_method = data.get('analyseMethod')
                measure_site_id = data.get('measureSiteId')
                #measure_gather_id = data.get('measureGatherId')
                measure_gather_id = data.get('gatherId')
                # sesor_id = data.get('sensorId')
                data_process = data.get('dataProcess')

                time_ = local_filename.replace("-", "").replace(" ", "").replace(":", "")+'00'
                print("local_filename",local_filename)
                print("analyse_method",analyse_method)
                print("measure_gather_id",measure_gather_id)
                print("measure_site_id",measure_site_id)
                print("data_process",data_process)
                print("time_",time_)
                # print("sensor_id: ", gather_id)
                # 通过sensorId取信号原始数据
                query = {
                    # 'sensorId':sesor_id,
                    'measureSiteId':int(measure_site_id),
                    'measureGatherId':int(measure_gather_id),
                    'time':time_
                }
                print("query",query)
                document = collection.find_one(query)
                # document = collection.find_one(query)
                #print("document",document)
                print(document is not None)
                print("analyse_method",analyse_method)
                if analyse_method=='spectrum' and document is not None:
                    # 提取 fs 字段 
                    fs = document.get('fs')
                    data = document.get('datas')
                    print(f", fs: {fs}")
                    print(f", dataType: {type(data)}")
                    # print(f", data: {data}")
                    # result = frequency_domain(data, fs)
                    result = spectrum(data, fs, methods=data_process)
                    return jsonify(result)
                elif analyse_method=='rms' and document is not None:  # Root Mean Square
                    print(f"analyse_method: in rms ")
                    fs = document.get('fs')
                    data = document.get('datas') 
                    result = velocity(data, fs)
                    return jsonify(result)
                elif analyse_method=='trend' and document is not None:
                    pass
                elif analyse_method=='envelope' and document is not None:
                    pass
                else:
                    return jsonify({
                        "status": "error",
                        "msg": "没有找到要查询的数据"
                        }), 400

        # 验证必需参数
        if measure_gather_id is None:
            return jsonify({
                "status": "error",
                "message": "缺少必需参数：sensor_id"
            }), 400
        # 执行函数
        # result = process_data(sensor_id)

        return jsonify(measure_gather_id)

    except Exception as e:
        return jsonify({
            "status": "error",
            "message": f"服务器错误：{str(e)}"
        }), 500


if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=6100)
